# CryptoFlow Environment Configuration
# Copy this file to .env and adjust values for your environment.

DATABASE_URL=postgresql://cryptoflow:<PASSWORD>@localhost:5432/cryptoflow
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=<GENERATE_A_SECURE_RANDOM_SECRET>
# ENVIRONMENT=production  # Uncomment for production (enforces JWT_SECRET change)

# pgAdmin4 credentials (used by pgadmin/setup.sh)
PGADMIN_EMAIL=admin@cryptoflow.local
PGADMIN_PASSWORD=<CHOOSE_A_SECURE_PASSWORD>
